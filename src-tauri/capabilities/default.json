{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default desktop capability",
  "windows": ["main", "image-viewer"],
  "webviews": ["main", "image-viewer"],
  "local": true,
  "permissions": [
    "core:default",
    "core:event:default",
    "dialog:default",
    "fs:default",
    {
      "identifier": "fs:scope",
      "allow": [
        { "path": "$APPDATA/scarecrow/**" },
        { "path": "$PICTURE/**" },
        { "path": "$DOCUMENT/**" },
        { "path": "$DOWNLOAD/**" },
        { "path": "$VIDEO/**" },
        { "path": "$DESKTOP/**" }
      ]
    },
    "shell:default",
    "sql:default",
    "sql:allow-execute",
    "sql:allow-select"
  ]
}
